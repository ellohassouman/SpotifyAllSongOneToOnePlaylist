# Spotify Developer Credentials
# Obtenez-les depuis https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=YOUR_CLIENT_ID_HERE
SPOTIFY_CLIENT_SECRET=YOUR_CLIENT_SECRET_HERE
SPOTIFY_REDIRECT_URI=http://localhost:3000/callback

# Token d'authentification (généré par npm run auth)
SPOTIFY_REFRESH_TOKEN=

# User ID Spotify (généré automatiquement lors de la première authentification)
SPOTIFY_USER_ID=

# Configuration optionnelle
PORT=3000
LOG_LEVEL=info
